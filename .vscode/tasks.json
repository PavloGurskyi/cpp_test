{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build cpp",
      "type": "process",
      "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
      "args": [
        "-g",
        "-std=c++17",
        "${file}",
        "-o",
        "${workspaceFolder}\\main.exe"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}
